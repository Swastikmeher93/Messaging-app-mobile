# GitHub Linguist overrides to show accurate language statistics for Flutter
# Mark platform boilerplate code as generated so it doesn't skew the language stats
macos/** linguist-generated=true
windows/** linguist-generated=true
linux/** linguist-generated=true
web/** linguist-generated=true
build/** linguist-generated=true

# Force tracking of Kotlin and Swift files in Android and iOS directories
android/**/*.kt linguist-detectable=true linguist-generated=false linguist-vendored=false
android/**/*.java linguist-detectable=true linguist-generated=false linguist-vendored=false
ios/**/*.swift linguist-detectable=true linguist-generated=false linguist-vendored=false
ios/**/*.m linguist-detectable=true linguist-generated=false linguist-vendored=false
ios/**/*.h linguist-detectable=true linguist-generated=false linguist-vendored=false
